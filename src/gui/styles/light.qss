QMainWindow { background-color: #f8f9fb; }
QGroupBox { font-weight: bold; border: 1px solid #d0d0d0; border-radius: 6px; margin-top: 8px; }
QGroupBox::title { subcontrol-origin: margin; left: 10px; padding: 0 6px 0 6px; }
QPushButton { padding: 6px 14px; border: 1px solid #c0c0c0; border-radius: 4px; background: #ffffff; }
QPushButton:hover { background: #eef3ff; }
QProgressBar { border: 1px solid #c0c0c0; border-radius: 4px; text-align: center; }
