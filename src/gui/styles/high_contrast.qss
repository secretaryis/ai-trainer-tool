QMainWindow { background-color: #000000; color: #ffffff; }
QGroupBox { font-weight: bold; border: 2px solid #ffffff; border-radius: 6px; margin-top: 8px; }
QGroupBox::title { subcontrol-origin: margin; left: 10px; padding: 0 6px 0 6px; color: #ffffff; }
QPushButton { padding: 8px 16px; border: 2px solid #ffffff; border-radius: 4px; background: #000000; color: #ffffff; }
QPushButton:hover { background: #222222; }
QProgressBar { border: 2px solid #ffffff; border-radius: 4px; text-align: center; color: #ffffff; }
